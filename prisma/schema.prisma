// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User roles enum
enum UserRole {
  USER
  SUPERVISOR
  SUPERADMIN
}

// User status enum
enum UserStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
}

// Gender enum
enum Gender {
  MALE
  FEMALE
}

// Match status enum
enum MatchStatus {
  ACTIVE
  UNMATCHED
  CLOSED
}

// Region model - geographical areas for supervision
model Region {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  supervisors User[] @relation("SupervisorRegion")

  @@map("regions")
}

// User model - core user entity
model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  password      String
  role          UserRole   @default(USER)
  status        UserStatus @default(PENDING_VERIFICATION)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Profile information
  name          String?
  gender        Gender?
  age           Int?
  height        Int?
  city          String?
  education     String?
  occupation    String?
  religionLevel String?
  aboutMe       String?
  photoUrls     String[] // Array of photo URLs

  // Region relationship
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  // Supervisor relationship (for supervisors only)
  supervisorRegionId String?
  supervisorRegion   Region? @relation("SupervisorRegion", fields: [supervisorRegionId], references: [id])

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // Discovery and matching relations
  likes          Like[]  @relation("UserLikes")
  likedBy        Like[]  @relation("UserLikedBy")
  passes         Pass[]  @relation("UserPasses")
  passedBy       Pass[]  @relation("UserPassedBy")
  matchesAsUser1 Match[] @relation("MatchUser1")
  matchesAsUser2 Match[] @relation("MatchUser2")
  closedMatches  Match[] @relation("MatchClosedBy")
  messages       Message[] @relation("UserMessages")

  @@map("users")
}

// Auth.js Account model (for OAuth providers)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Auth.js Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Auth.js VerificationToken model (for email verification)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Audit log model - tracks all supervisor/superadmin actions
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String // e.g., "APPROVE_USER", "REJECT_USER", "ASSIGN_SUPERVISOR", etc.
  target    String? // target user ID or resource ID
  details   String?  @db.Text // JSON string with action details
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// Like model - tracks when users like each other
model Like {
  id          String   @id @default(cuid())
  userId      String // User who liked
  likedUserId String // User who was liked
  createdAt   DateTime @default(now())

  user      User @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)
  likedUser User @relation("UserLikedBy", fields: [likedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, likedUserId])
  @@index([userId])
  @@index([likedUserId])
  @@index([createdAt])
  @@map("likes")
}

// Pass model - tracks when users pass on each other
model Pass {
  id           String   @id @default(cuid())
  userId       String // User who passed
  passedUserId String // User who was passed
  createdAt    DateTime @default(now())

  user       User @relation("UserPasses", fields: [userId], references: [id], onDelete: Cascade)
  passedUser User @relation("UserPassedBy", fields: [passedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, passedUserId])
  @@index([userId])
  @@index([passedUserId])
  @@map("passes")
}

// Match model - tracks mutual likes between users
model Match {
  id        String      @id @default(cuid())
  user1Id   String // First user in the match
  user2Id   String // Second user in the match
  status    MatchStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Closure tracking
  closedBy     String?   // ID of supervisor who closed it
  closedAt     DateTime?
  closedReason String?   @db.Text // Reason for closure

  user1    User      @relation("MatchUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("MatchUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  closedBySupervisor User? @relation("MatchClosedBy", fields: [closedBy], references: [id])
  messages Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([status])
  @@index([updatedAt])
  @@map("matches")
}

// Message model - stores chat messages between matched users
model Message {
  id        String   @id @default(cuid())
  matchId   String
  senderId  String
  content   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender User  @relation("UserMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}
