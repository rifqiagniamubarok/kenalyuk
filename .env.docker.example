# Copy this file to .env.docker before running Docker Compose.
# cp .env.docker.example .env.docker

# ---------- Database wiring (compose app <-> db) ----------
POSTGRES_DB=kenalyuk
POSTGRES_USER=kenalyuk
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql://kenalyuk:replace-with-strong-db-password@db:5432/kenalyuk?schema=public

# ---------- Auth.js / app runtime ----------
AUTH_SECRET=replace-with-long-random-secret
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=production

# ---------- Upload persistence path inside container ----------
UPLOAD_DIRECTORY=/app/public/uploads

# ---------- SMTP (transactional email) ----------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=No Reply <noreply@example.com>
SMTP_SECURE=false

# Backward compatibility for existing typo fallback in code (optional)
SMPTP_FROM=No Reply <noreply@example.com>
